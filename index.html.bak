<style>
:root {
--color-bone: #F6F1EA;
--color-obsidian: #121212;
--color-rose-gold: #B76E79;
--color-stone: #CFC8BE;
--color-card-tan: #D4C4A8;
}
body {
font-family: 'Plus Jakarta Sans', sans-serif;
background-color: var(--color-bone);
color: var(--color-obsidian);
-webkit-font-smoothing: antialiased;
}
h1, h2, h3, h4, h5, h6 {
font-family: 'Cormorant Garamond', serif;
}
.luxury-card {
background: rgba(246, 241, 234, 0.4);
backdrop-filter: blur(12px);
-webkit-backdrop-filter: blur(12px);
border: 1px solid rgba(18, 18, 18, 0.08);
box-shadow: 0 20px 40px -4px rgba(18, 18, 18, 0.05);
}
.bg-grain {
background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
}
.anatomy-card {
background-color: var(--color-card-tan);
box-shadow:
inset 0 0 40px rgba(0,0,0,0.05),
0 20px 40px -10px rgba(0,0,0,0.2);
}
.anatomy-image {
mix-blend-mode: multiply;
filter: grayscale(100%) contrast(120%) sepia(20%);
}
.arch-lines {
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 100%;
z-index: -1;
pointer-events: none;
opacity: 0.15;
}
@keyframes marquee {
0% { transform: translateX(0); }
100% { transform: translateX(-50%); }
}
.animate-marquee {
animation: marquee 40s linear infinite;
}
.mask-linear-fade {
mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
-webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
}
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: #F6F1EA; }
::-webkit-scrollbar-thumb { background: #CFC8BE; border-radius: 0; }
::-webkit-scrollbar-thumb:hover { background: #B76E79; }
</style>

<!-- aura-ga4-start -->
<script async="" src="https://www.googletagmanager.com/gtag/js?id=G-2M6V79H761"></script>
