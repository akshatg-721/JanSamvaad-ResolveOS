                    <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xs font-semibold tracking-[0.2em] uppercase">Return to Presence</span>
                     <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xl font-serif">Lead from Identity</span>
                     <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xs font-semibold tracking-[0.2em] uppercase">Nervous System Regulation</span>
                     <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xl font-serif italic">Regulate the body</span>
                    <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xs font-semibold tracking-[0.2em] uppercase">Return to Presence</span>
                     <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xl font-serif">Lead from Identity</span>
                     <iconify-icon icon="solar:star-linear" width="12" class="text-[#B76E79]"></iconify-icon>
                    <span class="text-xs font-semibold tracking-[0.2em] uppercase">Nervous System Regulation</span>
                </div>
            </div>
        </div>
