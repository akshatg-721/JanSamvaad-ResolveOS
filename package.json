    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "pg": "^8.13.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.1",
    "socket.io": "^4.8.1",
    "twilio": "^5.4.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/crm/ticket.js",
