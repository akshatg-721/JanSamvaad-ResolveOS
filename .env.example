# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/jansamvaad

# Auth
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
NEXTAUTH_SECRET=replace_with_a_long_random_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# Backend Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# URLs
APP_BASE_URL=http://localhost:3000
EVIDENCE_BASE_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3001
DASHBOARD_URL=http://localhost:3001

# Next.js Frontend (public vars must start with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Twilio (Voice IVR)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google AI
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# Duplicate Detection
DUPLICATE_LOOKBACK_DAYS=7
DUPLICATE_CANDIDATE_THRESHOLD=0.3
DUPLICATE_MATCH_THRESHOLD=0.6
DUPLICATE_ACTIVE_STATUSES=open,in_progress

# Email (Brevo SMTP)
BREVO_API_KEY=
SYSTEM_EMAIL=alerts@yourcitydomain.gov.in

# Cloudinary Uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nominatim Geocoding (required)
NOMINATIM_EMAIL=your@email.com

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Feature Flags
ENABLE_SLA_CRON=true
