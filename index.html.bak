    <!-- Hero Section -->
    <header class="relative pt-48 pb-32 px-6 overflow-hidden min-h-screen flex flex-col justify-center">
        <!-- New Anatomy Background Image -->
        <div class="absolute inset-0 z-0 select-none">
            <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/ae521738-d182-4d24-bcef-e60145c5ca21_3840w.png?w=800&amp;q=80" alt="Nervous System Anatomy" class="opacity-60 mix-blend-multiply w-full h-full object-cover">
            <!-- Fade overlay to blend with background color and ensure text readability -->
            <div class="absolute inset-0 bg-gradient-to-b from-[#F6F1EA]/80 via-[#F6F1EA]/50 to-[#F6F1EA] pointer-events-none"></div>
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(246,241,234,0.7)_0%,transparent_100%)] pointer-events-none"></div>
        </div>
        
        <div class="absolute inset-0 bg-grain pointer-events-none z-0 mix-blend-overlay opacity-50"></div>

        <div class="text-center max-w-5xl z-10 mr-auto ml-auto relative">
            <div class="inline-flex items-center gap-4 mb-12">
                <div class="h-[1px] w-12 bg-[#B76E79]"></div>
                <span class="text-xs font-medium uppercase tracking-[0.2em] text-[#121212]">Created by a Physiotherapist</span>
                <div class="h-[1px] w-12 bg-[#B76E79]"></div>
            </div>

            <h1 class="md:text-8xl leading-[1] text-6xl font-normal text-[#121212] tracking-tight font-serif mb-10">Confidence is trained <br> in the body, <br> <span class="italic text-[#121212] relative">not forced in the mind. <span class="absolute -bottom-2 left-0 w-full h-[1px] bg-[#B76E79]/40"></span></span></h1>
            
            <p class="text-xl md:text-2xl text-[#121212]/70 max-w-3xl mx-auto mb-16 leading-relaxed font-light">
                For high-capacity people who don't need motivation. They need regulation.
                <span class="font-normal text-[#121212] border-[#B76E79] border-b">CLIMB meets the body first so the mind doesn’t have to force clarity.</span>
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                <a href="#pricing" class="w-full sm:w-auto px-10 py-5 bg-[#121212] text-[#F6F1EA] font-medium text-xs uppercase tracking-widest hover:bg-[#333] transition-all hover:-translate-y-1 shadow-2xl shadow-black/10 flex items-center justify-center gap-4 group rounded-sm">
                    <iconify-icon icon="solar:play-circle-linear" width="20" height="20" stroke-width="1.5" class="group-hover:text-[#B76E79] transition-colors"></iconify-icon>
                    Start Regulation
                </a>
                <a href="#gem-method" class="w-full sm:w-auto px-10 py-5 bg-transparent border border-[#121212] text-[#121212] font-medium text-xs uppercase tracking-widest hover:bg-[#121212] hover:text-[#F6F1EA] transition-all flex items-center justify-center gap-4 rounded-sm backdrop-blur-sm">
                    The Method
                </a>
            </div>

            <!-- Hero Visual -->
            <div class="mt-32 relative mx-auto max-w-4xl">
                <div class="absolute -top-10 -right-10 w-40 h-40 border border-[#B76E79]/20 rounded-full"></div>
                <div class="absolute -bottom-10 -left-10 w-60 h-60 border border-[#121212]/5 rounded-full"></div>

                <div class="luxury-card p-1 md:p-2 relative overflow-hidden rounded-sm">
                    <div class="bg-[#FBF9F6] p-8 md:p-12 grid md:grid-cols-12 gap-12 items-center border border-[#fff]">
                        <!-- Player UI -->
                        <div class="md:col-span-5 relative">
                            <div class="aspect-square bg-[#F6F1EA] border border-[#121212]/10 flex flex-col items-center justify-center mb-8 relative overflow-hidden">
                                <div class="absolute inset-0 border-[0.5px] border-[#121212]/5 m-2"></div>
                                <div class="absolute inset-0 border-[0.5px] border-[#121212]/5 m-4"></div>
                                <iconify-icon icon="solar:soundwave-linear" class="text-[#B76E79]" width="48" height="48" stroke-width="1"></iconify-icon>
                            </div>
                            <div class="flex justify-between items-end mb-4">
                                <div class="">
                                    <h3 class="text-lg font-serif italic text-[#121212]">5 Senses Orientation</h3>
                                    <p class="text-xs uppercase tracking-widest text-[#121212]/50 mt-1">GemCoaching</p>
                                </div>
                                <iconify-icon icon="solar:menu-dots-linear" width="20" height="20" class="text-[#121212]/40" stroke-width="1.5"></iconify-icon>
                            </div>
                            <div class="h-[1px] w-full bg-[#121212]/10 mt-6 relative">
                                <div class="absolute left-0 top-0 h-full w-1/3 bg-[#121212]"></div>
                                <div class="absolute left-1/3 top-1/2 -translate-y-1/2 w-2 h-2 bg-[#121212] rounded-full"></div>
                            </div>
                            <div class="flex justify-between text-[0.65rem] text-[#121212]/40 font-medium mt-3 tracking-widest">
                                <span>02:14</span>
                                <span>07:00</span>
                            </div>
                        </div>

                        <!-- Copy -->
                        <div class="md:col-span-7 text-left">
                            <div class="flex items-center gap-3 text-[#B76E79] mb-6">
                                <iconify-icon icon="solar:verified-check-linear" width="16" height="16" stroke-width="1.5"></iconify-icon>
                                <span class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase text-[#121212]">Clinical Physiology</span>
                            </div>
                            <h2 class="text-3xl md:text-4xl font-serif text-[#121212] leading-tight mb-6 tracking-tight">
                                "Presence is physiological."
                            </h2>
                            <p class="text-[#121212]/60 leading-relaxed text-lg font-light">
                                You can't think your way out of stress. CLIMB helps you feel your way out. It tells your brain: <em>"We are safe."</em> When the body feels safe, clarity returns.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Tagline Marquee -->
    <section class="py-12 border-y border-[#121212]/5 bg-white/40 backdrop-blur-sm overflow-hidden">
        <div class="relative w-full overflow-hidden mask-linear-fade">
            <div class="flex whitespace-nowrap animate-marquee">
