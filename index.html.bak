                <a href="#climb" class="text-xs font-medium tracking-widest uppercase text-[#121212]/60 hover:text-[#121212] transition-colors">The Tool</a>
                <a href="#founder" class="text-xs font-medium tracking-widest uppercase text-[#121212]/60 hover:text-[#121212] transition-colors">Founder</a>
